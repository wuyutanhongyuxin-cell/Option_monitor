# Deribit API（测试网 key 在 test.deribit.com 免费注册获取）
DERIBIT_API_KEY=your_deribit_api_key
DERIBIT_API_SECRET=your_deribit_api_secret

# Derive（链上 session key，暂时留空）
DERIVE_PRIVATE_KEY=

# Telegram Bot（在 @BotFather 创建 bot 获取）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# 运行模式
USE_TESTNET=true
LOG_LEVEL=INFO
